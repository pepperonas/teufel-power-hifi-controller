[Unit]
Description=Teufel Power HiFi Controller — IR remote (Flask + pigpio)
After=network-online.target pigpiod.service
Wants=network-online.target pigpiod.service

[Service]
Type=simple
User=pi
SupplementaryGroups=gpio
WorkingDirectory=/home/pi/apps/powerhifi-controller
ExecStart=/home/pi/apps/powerhifi-controller/venv/bin/python server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
